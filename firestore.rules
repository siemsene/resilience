rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Instructors collection
    match /instructors/{uid} {
      // Anyone authenticated can create their own instructor doc
      allow create: if request.auth != null && request.auth.uid == uid;
      // Instructors can read their own doc
      allow read: if request.auth != null && (
        request.auth.uid == uid ||
        request.auth.token.email == resource.data.email ||
        isAdmin()
      );
      // Only admin can update (approve/deny/revoke)
      allow update: if isAdmin();
    }

    // Sessions collection
    match /sessions/{sessionId} {
      // Instructors can create sessions
      allow create: if request.auth != null && request.auth.token.role == 'instructor';
      // Anyone can read sessions (players need to see game state)
      allow read: if true;
      // Instructor who owns the session or admin can update
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.instructorUid ||
        isAdmin()
      );

      // Player states subcollection
      match /playerStates/{playerId} {
        allow read: if true;
        // Only Cloud Functions write player states
        allow write: if false;
      }

      // Round orders subcollection
      match /rounds/{roundNumber}/orders/{playerId} {
        allow read: if true;
        allow write: if false;
      }
    }

    function isAdmin() {
      return request.auth != null && (
        request.auth.token.role == 'admin' ||
        request.auth.token.admin == true ||
        request.auth.token.email == 'ADMIN_EMAIL_PLACEHOLDER'
      );
    }
  }
}
